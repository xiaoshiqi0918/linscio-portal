# 数据库 — 本地开发用 SQLite（设 DATABASE_URL），生产环境注释掉并配 DB_* 连 MySQL
DATABASE_URL=sqlite:///./dev.db
DB_HOST=localhost
DB_PORT=3306
DB_NAME=linscio_db
DB_USER=linscio
DB_PASSWORD=change_me

# COS
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_APPID=1363203425
COS_BUCKET_RELEASES=linscio-releases-1363203425
COS_BUCKET_SPECIALTIES=linscio-specialties-1363203425
COS_REGION=ap-shanghai

# CDN
CDN_DOMAIN_RELEASES=releases.linscio.com.cn
CDN_DOMAIN_SPECIALTIES=cdn.linscio.com.cn
