# 复制为服务器上的 /home/linscio/api/.env 并填写真实值；勿提交含密钥的 .env

# 数据库 — 生产环境不要设置 DATABASE_URL（或注释掉），使用 DB_* 连接 MySQL
# DATABASE_URL=sqlite:///./dev.db
DB_HOST=localhost
DB_PORT=3306
DB_NAME=linscio_db
DB_USER=linscio
DB_PASSWORD=change_me

# COS
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_APPID=1363203425
COS_BUCKET_RELEASES=linscio-releases-1363203425
COS_BUCKET_SPECIALTIES=linscio-specialties-1363203425
COS_REGION=ap-shanghai

# CDN
CDN_DOMAIN_RELEASES=releases.linscio.com.cn
CDN_DOMAIN_SPECIALTIES=cdn.linscio.com.cn
CDN_AUTH_SECRET=change_me_32_chars_random_string

# 邮件
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_auth_code

# 安全 — 生产必须更换
SECRET_KEY=change_me_64_chars_random_string
# 管理接口 /admin/* 在生产环境会校验来源 IP（见 get_client_ip：X-Real-IP、X-Forwarded-For）。
# 从公网打开 admin 后台时，须把你的公网 IP 写进列表（可多个，逗号分隔）；仅 127.0.0.1 时外网登录后请求 /admin 会 403。
# 若留空则不做 IP 校验（不推荐）。
ADMIN_IPS=127.0.0.1

# 应用
ENV=production
API_BASE_URL=https://api.linscio.com.cn

# 浏览器前端跨域（桌面客户端直连 api 域名不受 CORS 限制）
CORS_ORIGINS=https://portal.linscio.com.cn,https://admin.linscio.com.cn,https://www.linscio.com.cn,https://medcomm.linscio.com.cn,https://schola.linscio.com.cn,https://qcc.linscio.com.cn,https://stats.linscio.com.cn,https://docs.linscio.com.cn
